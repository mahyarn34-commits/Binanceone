# توکن ربات که از BotFather می‌گیری
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# chat_id ای که ربات باید گزارش‌های خودکار رو براش بفرسته
# (اول ربات رو /start کن، عددی که برات می‌فرسته رو اینجا بذار)
TELEGRAM_CHAT_ID=

# چند تا از پرحجم‌ترین کوین‌های USDT اسکن بشن
TOP_N_SYMBOLS=40

# حداقل حجم ۲۴ ساعته به دلار برای ورود به اسکن
MIN_QUOTE_VOLUME=5000000

# هر چند دقیقه یک‌بار اسکن خودکار انجام بشه
SCAN_INTERVAL_MINUTES=15
